# Core profile for cloud Ark / Doubao calls.
# Fill RAG_ANSWER_MODEL with your doubao-2.0-pro Ark endpoint id.

RAG_MODEL_PROVIDER=ark
RAG_EMBEDDING_PROVIDER=ark
RAG_EMBEDDING_MODEL=doubao-embedding-vision-250615
ARK_EMBEDDING_DIMENSIONS=1024

RAG_VISUAL_CAPTION_PROVIDER=qwen
RAG_QWEN_VL_MODEL=qwen-vl-plus
RAG_QWEN_API_KEY_ENV=DASHSCOPE_API_KEY
RAG_VISUAL_MAX_CAPTIONS=0

RAG_PDF_PARSER=mineru
RAG_MINERU_OUTPUT_DIR=outputs/mineru
# MinerU parsing:
# - leave MINERU_API_KEY empty to use local mineru.exe
# - set MINERU_API_KEY and MINERU_API_MODE=cloud to use MinerU OpenAPI
MINERU_API_MODE=local
MINERU_API_URL=https://mineru.net/api/v4
MINERU_API_KEY=
MINERU_API_MODEL_VERSION=vlm
MINERU_API_ENABLE_FORMULA=true
MINERU_API_ENABLE_TABLE=true
MINERU_API_TIMEOUT=1800
MINERU_API_POLL_INTERVAL=5
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_MODEL_SOURCE=local
MINERU_TOOLS_CONFIG_JSON=D:\ai_models\mineru\mineru.json
MINERU_DEVICE_MODE=cuda
MINERU_API_OUTPUT_ROOT=D:\ai_models\mineru_api_outputs
MINERU_API_MAX_CONCURRENT_REQUESTS=1

RAG_ANSWER_PROVIDER=ark
RAG_ANSWER_MODEL=<your-doubao-2.0-pro-endpoint-id>
RAG_ANSWER_TEMPERATURE=0.12
RAG_ANSWER_MAX_TOKENS=700

# Optional external reranker. Leave empty in pure Ark mode, or point to Xinference/local below.
RAG_RERANK_PROVIDER=
RAG_RERANK_MODEL=
RAG_ENABLE_MODEL_RERANK=1
RAG_MODEL_RERANK_WEIGHT=0.08

# Alternative model gateway mode: Xinference.
# Uncomment and fill model UIDs after launching models in Xinference.
# RAG_MODEL_PROVIDER=xinference
# RAG_EMBEDDING_PROVIDER=xinference
# RAG_ANSWER_PROVIDER=xinference
# RAG_RERANK_PROVIDER=xinference
# RAG_VISUAL_CAPTION_PROVIDER=xinference
# XINFERENCE_BASE_URL=http://127.0.0.1:9997/v1
# XINFERENCE_API_KEY=not-used
# XINFERENCE_LLM_MODEL=<xinference-llm-uid>
# XINFERENCE_EMBEDDING_MODEL=<xinference-embedding-uid>
# XINFERENCE_VISION_MODEL=<xinference-vlm-uid>
# XINFERENCE_RERANK_MODEL=<xinference-rerank-uid>

# Alternative model gateway mode: any local OpenAI-compatible server.
# RAG_MODEL_PROVIDER=openai_compatible
# RAG_EMBEDDING_PROVIDER=openai_compatible
# RAG_ANSWER_PROVIDER=openai_compatible
# RAG_RERANK_PROVIDER=openai_compatible
# RAG_VISUAL_CAPTION_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_COMPATIBLE_API_KEY=not-used
# OPENAI_COMPATIBLE_LLM_MODEL=<local-chat-model>
# OPENAI_COMPATIBLE_EMBEDDING_MODEL=<local-embedding-model>
# OPENAI_COMPATIBLE_VISION_MODEL=<local-vlm-model>
# OPENAI_COMPATIBLE_RERANK_MODEL=<local-rerank-model>

RAG_BACKEND_CANDIDATE_RETRIEVER=fusion
RAG_BACKEND_RERANK_RETRIEVER=fusion
RAG_BACKEND_CANDIDATE_K=50
RAG_BACKEND_RERANK_K=10
RAG_BACKEND_HYBRID_ALPHA=0.7
RAG_BACKEND_ENABLE_KG=1
RAG_KG_DIR=outputs/graphrag
