# Core profile that reuses the stronger DataFountain setup.
# Fill RAG_ANSWER_MODEL with your doubao-2.0-pro Ark endpoint id.

RAG_EMBEDDING_PROVIDER=ark
RAG_EMBEDDING_MODEL=doubao-embedding-vision-250615
ARK_EMBEDDING_DIMENSIONS=1024

RAG_PDF_PARSER=mineru
RAG_MINERU_OUTPUT_DIR=outputs/mineru
MINERU_API_URL=
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_MODEL_SOURCE=local
MINERU_TOOLS_CONFIG_JSON=D:\ai_models\mineru\mineru.json
MINERU_DEVICE_MODE=cuda
MINERU_API_OUTPUT_ROOT=D:\ai_models\mineru_api_outputs
MINERU_API_MAX_CONCURRENT_REQUESTS=1

RAG_ANSWER_PROVIDER=ark
RAG_ANSWER_MODEL=<your-doubao-2.0-pro-endpoint-id>
RAG_ANSWER_TEMPERATURE=0.12
RAG_ANSWER_MAX_TOKENS=700

RAG_BACKEND_CANDIDATE_RETRIEVER=fusion
RAG_BACKEND_RERANK_RETRIEVER=fusion
RAG_BACKEND_CANDIDATE_K=50
RAG_BACKEND_RERANK_K=10
RAG_BACKEND_HYBRID_ALPHA=0.7
