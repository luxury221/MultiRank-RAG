# Copy this file to `.env` and fill local secrets there.
# `.env` is ignored by Git and should never be committed.

MINERU_API_MODE=cloud
MINERU_API_URL=https://mineru.net/api/v4
MINERU_API_KEY=
MINERU_API_MODEL_VERSION=vlm
MINERU_API_ENABLE_FORMULA=true
MINERU_API_ENABLE_TABLE=true

RAG_PDF_PARSER=mineru
RAG_KG_DIR=outputs/graphrag

# Unified model gateway.
# Choose one: ark | xinference | openai_compatible
# ark: direct cloud API calls, usually Doubao/Qwen endpoints.
# xinference: one local gateway at http://127.0.0.1:9997/v1.
# openai_compatible: any local OpenAI-compatible server, e.g. vLLM/LM Studio/Ollama proxy.
RAG_MODEL_PROVIDER=ark

# Direct Ark / Doubao mode.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision-250615
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_ANSWER_PROVIDER=fallback
RAG_ANSWER_MODEL=
RAG_RERANK_PROVIDER=
RAG_RERANK_MODEL=

# Qwen-VL visual caption mode. Keep this if you use DashScope directly.
DASHSCOPE_API_KEY=
RAG_VISUAL_CAPTION_PROVIDER=local
RAG_QWEN_VL_MODEL=qwen-vl-plus
RAG_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Xinference mode. Fill these when RAG_MODEL_PROVIDER=xinference.
XINFERENCE_BASE_URL=http://127.0.0.1:9997/v1
XINFERENCE_API_KEY=not-used
XINFERENCE_LLM_MODEL=
XINFERENCE_EMBEDDING_MODEL=
XINFERENCE_VISION_MODEL=
XINFERENCE_RERANK_MODEL=

# Generic local OpenAI-compatible mode. Fill these when RAG_MODEL_PROVIDER=openai_compatible.
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_COMPATIBLE_API_KEY=not-used
OPENAI_COMPATIBLE_LLM_MODEL=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=
OPENAI_COMPATIBLE_VISION_MODEL=
OPENAI_COMPATIBLE_RERANK_MODEL=

# Optional model-rerank blending in G4. It only runs when a rerank provider/model is configured.
RAG_ENABLE_MODEL_RERANK=1
RAG_MODEL_RERANK_WEIGHT=0.08
